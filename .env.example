# Server
PORT=3000
# Public base used to build returned short URLs (the "sho.rt" domain in the docs)
BASE_URL=http://localhost:3000

# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://urlshort:urlshort@localhost:55432/urlshort?schema=public"

# Redis cache (optional — app runs without it, just slower on the hot path)
REDIS_URL=redis://localhost:56379

# Short-code generation
CODE_LENGTH=7

# Cache TTL for redirect lookups, in seconds
CACHE_TTL_SECONDS=3600

# Rate limiting for the create endpoint (fixed window)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=60

# Redirect status: 301 (permanent, browser-cached) or 302 (found, re-checks each click)
# 302 is the default so expiry (F5) is honored on every visit.
REDIRECT_STATUS=302
